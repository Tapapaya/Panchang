{
  "$meta": {
    "name": "Panchang Design Tokens",
    "version": "1.0.0",
    "date": "2026-06-16",
    "typography": "Urbanist (400 / 500 / 600 / 700)",
    "grid": "8pt base, 4pt micro",
    "notation": "Nested objects. Flatten with '/' separators for code vars: color.brand.primary → color/brand/primary",
    "platforms": ["react-native", "web"]
  },

  "color": {

    "brand": {
      "primary":       { "$value": "#FF660E", "$desc": "Core orange — CTAs, active states, highlights" },
      "primary-dark":  { "$value": "#CC4D00", "$desc": "Pressed / hover state for primary" },
      "primary-light": { "$value": "#FF8A4C", "$desc": "Softer orange — icons on dark bg" },
      "primary-wash":  { "$value": "#FFF0E8", "$desc": "Tint bg for featured / sacred content cards" },
      "primary-glow":  { "$value": "rgba(255,102,14,0.28)", "$desc": "Shadow glow on orange CTAs" },
      "inverse":       { "$value": "#1A1A1A", "$desc": "Dark band — hero card, sunrise/sunset" }
    },

    "neutral": {
      "0":    { "$value": "#FFFFFF" },
      "50":   { "$value": "#F8F8F8" },
      "100":  { "$value": "#F5F5F5", "$desc": "Page canvas" },
      "150":  { "$value": "#EFEFEF", "$desc": "Dim surface / pressed / skeleton" },
      "200":  { "$value": "#EBEBEB", "$desc": "Hairline / divider" },
      "250":  { "$value": "#DCDCDC" },
      "300":  { "$value": "#C8C8C8", "$desc": "Disabled border / placeholder text" },
      "400":  { "$value": "#A5A5A5", "$desc": "Secondary / muted text" },
      "500":  { "$value": "#808080" },
      "600":  { "$value": "#5C5C5C" },
      "700":  { "$value": "#3D3D3D" },
      "800":  { "$value": "#1A1A1A", "$desc": "Dark band inverse surface" },
      "900":  { "$value": "#0A0A0A" },
      "1000": { "$value": "#000000", "$desc": "Primary ink" }
    },

    "category": {
      "lilac": { "$value": "#EEECFF", "$desc": "Vastu — periwinkle tint" },
      "cream": { "$value": "#FFF8EE", "$desc": "Vastu — warm sand tint" },
      "mint":  { "$value": "#EEFAF3", "$desc": "Vastu — cool sage tint" },
      "lime":  { "$value": "#F4FAE8", "$desc": "Vastu — soft lime tint" },
      "pink":  { "$value": "#FFEFF5", "$desc": "Vastu — soft rose tint" },
      "coral": { "$value": "#FFF0E8", "$desc": "Alias → brand/primary-wash" }
    },

    "background": {
      "page":         { "$value": "{color.neutral.100}", "$desc": "Screen / page canvas" },
      "surface":      { "$value": "{color.neutral.0}",   "$desc": "Card & elevated surface" },
      "surface-dim":  { "$value": "{color.neutral.150}",  "$desc": "Pressed / skeleton state" },
      "inverse":      { "$value": "{color.brand.inverse}", "$desc": "Dark hero band" },
      "brand":        { "$value": "{color.brand.primary}" },
      "brand-wash":   { "$value": "{color.brand.primary-wash}" },
      "overlay":      { "$value": "rgba(0,0,0,0.48)",    "$desc": "Modal scrim" },
      "overlay-light":{ "$value": "rgba(0,0,0,0.20)",    "$desc": "Tooltip / popover scrim" }
    },

    "text": {
      "primary":       { "$value": "{color.neutral.1000}", "$desc": "Headlines, body on light bg" },
      "secondary":     { "$value": "{color.neutral.600}",  "$desc": "Supporting labels" },
      "tertiary":      { "$value": "{color.neutral.400}",  "$desc": "Muted, meta info" },
      "placeholder":   { "$value": "rgba(0,0,0,0.35)",     "$desc": "Input placeholders" },
      "disabled":      { "$value": "{color.neutral.300}" },
      "inverse":       { "$value": "{color.neutral.0}",    "$desc": "Text on dark/colored bg" },
      "inverse-soft":  { "$value": "rgba(255,255,255,0.65)", "$desc": "Secondary text on dark band" },
      "brand":         { "$value": "{color.brand.primary}", "$desc": "Accent labels, prices, links" }
    },

    "border": {
      "hairline":  { "$value": "{color.neutral.200}",      "$desc": "Dividers, card outlines" },
      "default":   { "$value": "{color.neutral.250}",      "$desc": "Input default stroke" },
      "strong":    { "$value": "{color.neutral.400}",      "$desc": "Focused but not brand" },
      "brand":     { "$value": "{color.brand.primary}",    "$desc": "Active input, selected card" },
      "inverse":   { "$value": "rgba(255,255,255,0.12)",   "$desc": "Borders on dark band" }
    },

    "icon": {
      "default":   { "$value": "{color.neutral.800}" },
      "secondary":  { "$value": "{color.neutral.400}" },
      "brand":     { "$value": "{color.brand.primary}" },
      "inverse":   { "$value": "{color.neutral.0}" },
      "disabled":  { "$value": "{color.neutral.300}" }
    },

    "feedback": {
      "success":        { "$value": "#1EA64A" },
      "success-dark":   { "$value": "#157A35" },
      "success-wash":   { "$value": "#EAFBF0" },
      "error":          { "$value": "#C82014" },
      "error-dark":     { "$value": "#9C1810" },
      "error-wash":     { "$value": "#FEF2F2" },
      "warning":        { "$value": "#E8A000" },
      "warning-dark":   { "$value": "#B87D00" },
      "warning-wash":   { "$value": "#FFF8E6" },
      "info":           { "$value": "#2463EB" },
      "info-dark":      { "$value": "#1A4DB8" },
      "info-wash":      { "$value": "#EEF3FE" }
    },

    "interactive": {
      "default":    { "$value": "{color.brand.primary}" },
      "hover":      { "$value": "{color.brand.primary-dark}" },
      "pressed":    { "$value": "#B34400" },
      "disabled-bg":{ "$value": "{color.neutral.150}" },
      "disabled-fg":{ "$value": "{color.neutral.300}" },
      "focus-ring": { "$value": "{color.brand.primary}" }
    }
  },

  "typography": {

    "family": {
      "base": { "$value": "Urbanist",    "$desc": "Primary — all UI text" },
      "mono": { "$value": "Courier New", "$desc": "IAST diacritics, code snippets" }
    },

    "weight": {
      "regular":  { "$value": "400" },
      "medium":   { "$value": "500" },
      "semibold": { "$value": "600" },
      "bold":     { "$value": "700" }
    },

    "size": {
      "2xs":  { "$value": 10 },
      "xs":   { "$value": 11 },
      "sm":   { "$value": 12 },
      "md":   { "$value": 13 },
      "base": { "$value": 14 },
      "lg":   { "$value": 16 },
      "xl":   { "$value": 17 },
      "2xl":  { "$value": 20 },
      "3xl":  { "$value": 24 },
      "4xl":  { "$value": 28 },
      "5xl":  { "$value": 32 },
      "6xl":  { "$value": 38 },
      "7xl":  { "$value": 48 },
      "8xl":  { "$value": 52,  "$desc": "displayHero — tithi name, ONE BIG MOMENT" }
    },

    "line-height": {
      "tighter":  { "$value": 1.1  },
      "tight":    { "$value": 1.2  },
      "snug":     { "$value": 1.3  },
      "normal":   { "$value": 1.4  },
      "relaxed":  { "$value": 1.55 },
      "loose":    { "$value": 1.7  }
    },

    "letter-spacing": {
      "tightest": { "$value": -1.0 },
      "tighter":  { "$value": -0.6 },
      "tight":    { "$value": -0.3 },
      "snug":     { "$value": -0.2 },
      "normal":   { "$value": 0    },
      "wide":     { "$value": 0.1  },
      "wider":    { "$value": 0.4  },
      "widest":   { "$value": 1.0  },
      "ultrawide":{ "$value": 1.5  }
    },

    "scale": {
      "display/hero": {
        "$desc": "52px — Tithi name, the single editorial moment per screen",
        "fontFamily":    "Urbanist_700Bold",
        "fontSize":      52,
        "lineHeight":    56,
        "letterSpacing": -1.0
      },
      "display/xl": {
        "$desc": "38px — Section hero, full-bleed callouts",
        "fontFamily":    "Urbanist_700Bold",
        "fontSize":      38,
        "lineHeight":    44,
        "letterSpacing": -0.6
      },
      "display/lg": {
        "$desc": "28px — Card-level hero text",
        "fontFamily":    "Urbanist_700Bold",
        "fontSize":      28,
        "lineHeight":    34,
        "letterSpacing": -0.3
      },
      "heading/xl": {
        "$desc": "20px — Screen titles, modal headers",
        "fontFamily":    "Urbanist_600SemiBold",
        "fontSize":      20,
        "lineHeight":    26,
        "letterSpacing": -0.2
      },
      "heading/lg": {
        "$desc": "18px — Card section headings",
        "fontFamily":    "Urbanist_600SemiBold",
        "fontSize":      18,
        "lineHeight":    24,
        "letterSpacing": -0.1
      },
      "heading/md": {
        "$desc": "16px — Sub-section titles",
        "fontFamily":    "Urbanist_600SemiBold",
        "fontSize":      16,
        "lineHeight":    22,
        "letterSpacing": -0.1
      },
      "body/xl": {
        "$desc": "17px — Sub-headline companion text",
        "fontFamily":    "Urbanist_400Regular",
        "fontSize":      17,
        "lineHeight":    25,
        "letterSpacing": 0
      },
      "body/lg": {
        "$desc": "16px — Primary reading text",
        "fontFamily":    "Urbanist_400Regular",
        "fontSize":      16,
        "lineHeight":    26,
        "letterSpacing": 0
      },
      "body/md": {
        "$desc": "14px — Default body, card copy",
        "fontFamily":    "Urbanist_400Regular",
        "fontSize":      14,
        "lineHeight":    22,
        "letterSpacing": 0
      },
      "body/sm": {
        "$desc": "13px — Dense secondary text",
        "fontFamily":    "Urbanist_400Regular",
        "fontSize":      13,
        "lineHeight":    20,
        "letterSpacing": 0
      },
      "label/lg": {
        "$desc": "14px 600 — Button text, active chip labels",
        "fontFamily":    "Urbanist_600SemiBold",
        "fontSize":      14,
        "lineHeight":    18,
        "letterSpacing": 0.1
      },
      "label/md": {
        "$desc": "13px 600 — Tab labels, compact actions",
        "fontFamily":    "Urbanist_600SemiBold",
        "fontSize":      13,
        "lineHeight":    17,
        "letterSpacing": 0.1
      },
      "label/sm": {
        "$desc": "12px 600 — Badge text, filter tags",
        "fontFamily":    "Urbanist_600SemiBold",
        "fontSize":      12,
        "lineHeight":    16,
        "letterSpacing": 0.2
      },
      "caption/md": {
        "$desc": "11px — Meta, timestamps, helper text",
        "fontFamily":    "Urbanist_500Medium",
        "fontSize":      11,
        "lineHeight":    14,
        "letterSpacing": 0.4
      },
      "eyebrow/md": {
        "$desc": "11px uppercase — Section category labels",
        "fontFamily":    "Urbanist_600SemiBold",
        "fontSize":      11,
        "lineHeight":    14,
        "letterSpacing": 1.0,
        "textTransform": "uppercase"
      },
      "mono/iast": {
        "$desc": "13px mono — IAST transliteration of Sanskrit shlokas",
        "fontFamily":    "Courier New",
        "fontSize":      13,
        "lineHeight":    20,
        "letterSpacing": 0.3
      }
    }
  },

  "spacing": {
    "$desc": "8pt grid. 4pt micro-steps for tight component internals only.",

    "raw": {
      "0":    { "$value": 0   },
      "0.5":  { "$value": 2,  "$desc": "4pt micro — icon-to-label gap" },
      "1":    { "$value": 4   },
      "1.5":  { "$value": 6   },
      "2":    { "$value": 8   },
      "3":    { "$value": 12  },
      "4":    { "$value": 16  },
      "5":    { "$value": 20  },
      "6":    { "$value": 24  },
      "7":    { "$value": 28  },
      "8":    { "$value": 32  },
      "9":    { "$value": 36  },
      "10":   { "$value": 40  },
      "12":   { "$value": 48  },
      "14":   { "$value": 56  },
      "16":   { "$value": 64  },
      "20":   { "$value": 80  },
      "24":   { "$value": 96  },
      "30":   { "$value": 120 }
    },

    "semantic": {
      "none":  { "$value": 0  },
      "hair":  { "$value": 1  },
      "2xs":   { "$value": 4  },
      "xs":    { "$value": 8  },
      "sm":    { "$value": 12 },
      "md":    { "$value": 16 },
      "lg":    { "$value": 24 },
      "xl":    { "$value": 32 },
      "2xl":   { "$value": 56 }
    },

    "layout": {
      "gutter":       { "$value": 20, "$desc": "Horizontal screen margin" },
      "column-gap":   { "$value": 12, "$desc": "Gap between grid columns" },
      "section-gap":  { "$value": 32, "$desc": "Vertical gap between page sections" },
      "screen-top":   { "$value": 16, "$desc": "Top padding below safe area" }
    },

    "component": {
      "card-padding":   { "$value": 16 },
      "card-gap":       { "$value": 12, "$desc": "Vertical gap between cards in a list" },
      "button-h":       { "$value": 20, "$desc": "Button horizontal padding" },
      "button-v":       { "$value": 16, "$desc": "Button vertical padding" },
      "button-sm-h":    { "$value": 16 },
      "button-sm-v":    { "$value": 10 },
      "input-h":        { "$value": 16 },
      "input-v":        { "$value": 14 },
      "chip-h":         { "$value": 12 },
      "chip-v":         { "$value": 6  },
      "icon-gap":       { "$value": 6,  "$desc": "Icon to label gap" },
      "list-item-v":    { "$value": 14, "$desc": "List row vertical padding" },
      "tab-bar-h":      { "$value": 12 },
      "tab-bar-v":      { "$value": 8  },
      "section-title-gap": { "$value": 12, "$desc": "Gap below section eyebrow/title" }
    }
  },

  "radius": {
    "none": { "$value": 0    },
    "xs":   { "$value": 2    },
    "sm":   { "$value": 4    },
    "md":   { "$value": 8    },
    "lg":   { "$value": 12   },
    "xl":   { "$value": 16   },
    "2xl":  { "$value": 20   },
    "3xl":  { "$value": 24   },
    "4xl":  { "$value": 32   },
    "full": { "$value": 9999 },

    "semantic": {
      "button":       { "$value": 9999, "$desc": "Pill — all primary + secondary buttons" },
      "button-sm":    { "$value": 20,   "$desc": "Small action buttons" },
      "card":         { "$value": 16,   "$desc": "Standard content cards" },
      "card-lg":      { "$value": 20,   "$desc": "Featured / hero cards" },
      "card-hero":    { "$value": 0,    "$desc": "Dark hero band — intentionally edge-to-edge" },
      "input":        { "$value": 12,   "$desc": "Text inputs, search bars" },
      "chip":         { "$value": 9999, "$desc": "Filter chips, category pills" },
      "badge":        { "$value": 9999 },
      "avatar":       { "$value": 9999 },
      "modal":        { "$value": 24 },
      "bottom-sheet": { "$value": 24,   "$desc": "Top corners only" },
      "toast":        { "$value": 12 },
      "tooltip":      { "$value": 8  },
      "tag":          { "$value": 6  },
      "tab-pill":     { "$value": 9999, "$desc": "Active tab indicator pill" },
      "image":        { "$value": 12 }
    }
  },

  "shadow": {
    "$desc": "React Native format. 'elevation' for Android; shadowColor/Offset/Opacity/Radius for iOS.",

    "0": {
      "$desc": "No shadow — flat",
      "shadowColor":   "transparent",
      "shadowOffset":  { "width": 0, "height": 0 },
      "shadowOpacity": 0,
      "shadowRadius":  0,
      "elevation":     0
    },
    "1": {
      "$desc": "Hairline — barely lifts off canvas",
      "shadowColor":   "#000000",
      "shadowOffset":  { "width": 0, "height": 1 },
      "shadowOpacity": 0.06,
      "shadowRadius":  3,
      "elevation":     1
    },
    "2": {
      "$desc": "Card — default white card on gray canvas",
      "shadowColor":   "#000000",
      "shadowOffset":  { "width": 0, "height": 1 },
      "shadowOpacity": 0.08,
      "shadowRadius":  4,
      "elevation":     2
    },
    "3": {
      "$desc": "Float — chips, popovers, dropdown menus",
      "shadowColor":   "#000000",
      "shadowOffset":  { "width": 0, "height": 2 },
      "shadowOpacity": 0.10,
      "shadowRadius":  8,
      "elevation":     4
    },
    "4": {
      "$desc": "Raised — modals, action sheets (medium)",
      "shadowColor":   "#000000",
      "shadowOffset":  { "width": 0, "height": 4 },
      "shadowOpacity": 0.12,
      "shadowRadius":  16,
      "elevation":     8
    },
    "5": {
      "$desc": "Overlay — full bottom sheets, deep modals",
      "shadowColor":   "#000000",
      "shadowOffset":  { "width": 0, "height": 8 },
      "shadowOpacity": 0.16,
      "shadowRadius":  32,
      "elevation":     16
    },
    "sheet": {
      "$desc": "Bottom sheet — upward shadow from bottom edge",
      "shadowColor":   "#000000",
      "shadowOffset":  { "width": 0, "height": -4 },
      "shadowOpacity": 0.10,
      "shadowRadius":  16,
      "elevation":     16
    },
    "brand": {
      "$desc": "Orange glow — active CTA button, featured card ring",
      "shadowColor":   "#FF660E",
      "shadowOffset":  { "width": 0, "height": 4 },
      "shadowOpacity": 0.30,
      "shadowRadius":  16,
      "elevation":     6
    },

    "semantic": {
      "card":         { "$ref": "shadow.2",     "$desc": "Standard content card" },
      "featured-card":{ "$ref": "shadow.3",     "$desc": "Vrat / highlighted card" },
      "hero-card":    { "$ref": "shadow.0",     "$desc": "Dark band — no shadow needed" },
      "button":       { "$ref": "shadow.brand", "$desc": "Primary CTA button glow" },
      "bottom-sheet": { "$ref": "shadow.sheet" },
      "modal":        { "$ref": "shadow.4" },
      "toast":        { "$ref": "shadow.3" },
      "dropdown":     { "$ref": "shadow.3" }
    }
  },

  "motion": {
    "$desc": "Duration in ms. Easing names map to React Native Easing presets.",

    "duration": {
      "instant":   { "$value": 0   },
      "fast":      { "$value": 120 },
      "base":      { "$value": 200 },
      "moderate":  { "$value": 300 },
      "slow":      { "$value": 450 },
      "page":      { "$value": 380, "$desc": "Screen push / pop transitions" }
    },

    "easing": {
      "standard":    { "$value": "easeInOut", "$desc": "Most UI motion" },
      "decelerate":  { "$value": "easeOut",   "$desc": "Elements entering the screen" },
      "accelerate":  { "$value": "easeIn",    "$desc": "Elements leaving the screen" },
      "spring":      { "$value": "spring",    "$desc": "Bounce — bottom sheets, modals" }
    },

    "spring": {
      "gentle": {
        "damping":   18,
        "stiffness": 120,
        "mass":      1,
        "$desc":     "Smooth modal entrance"
      },
      "snappy": {
        "damping":   22,
        "stiffness": 220,
        "mass":      1,
        "$desc":     "Tab switches, chip toggles"
      }
    }
  },

  "size": {
    "$desc": "Fixed component dimensions — heights, icon sizes, avatar sizes.",

    "icon": {
      "xs":  { "$value": 14 },
      "sm":  { "$value": 16 },
      "md":  { "$value": 20 },
      "lg":  { "$value": 24 },
      "xl":  { "$value": 28 },
      "2xl": { "$value": 32 }
    },

    "avatar": {
      "xs":  { "$value": 24 },
      "sm":  { "$value": 32 },
      "md":  { "$value": 44 },
      "lg":  { "$value": 56 },
      "xl":  { "$value": 72 },
      "2xl": { "$value": 96 }
    },

    "button": {
      "sm":   { "$value": 36, "$desc": "Height — small / secondary actions" },
      "md":   { "$value": 44, "$desc": "Height — standard buttons" },
      "lg":   { "$value": 52, "$desc": "Height — primary CTAs" },
      "full": { "$value": 56, "$desc": "Height — full-width bottom CTAs" }
    },

    "input": {
      "sm":   { "$value": 40 },
      "md":   { "$value": 48 },
      "lg":   { "$value": 56 }
    },

    "tab-bar": {
      "height": { "$value": 64, "$desc": "Total tab bar height incl. home indicator padding" },
      "icon":   { "$value": 22 },
      "label":  { "$value": 10 }
    },

    "card": {
      "glance-width":  { "$value": 112, "$desc": "Horizontal glance strip card width" },
      "glance-height": { "$value": 108, "$desc": "Horizontal glance strip card height" },
      "hero-min-height": { "$value": 200, "$desc": "Tithi dark hero card min height" }
    },

    "touch-target": {
      "min": { "$value": 44, "$desc": "WCAG 2.2 minimum touch target" }
    }
  },

  "opacity": {
    "0":        { "$value": 0    },
    "disabled": { "$value": 0.38 },
    "faint":    { "$value": 0.50 },
    "soft":     { "$value": 0.65 },
    "medium":   { "$value": 0.80 },
    "strong":   { "$value": 0.92 },
    "full":     { "$value": 1    }
  },

  "z-index": {
    "base":        { "$value": 0   },
    "raised":      { "$value": 10  },
    "dropdown":    { "$value": 100 },
    "sticky":      { "$value": 200 },
    "modal":       { "$value": 300 },
    "bottom-sheet":{ "$value": 400 },
    "toast":       { "$value": 500 },
    "overlay":     { "$value": 600 }
  }
}
