{
  "$meta": {
    "name": "Panchang Design Tokens — Soft Data",
    "version": "3.0.0",
    "date": "2026-07-19",
    "typography": "Manrope (400 / 500 / 600 / 700 / 800)",
    "reference": "Rounded fintech-statistics aesthetic, light mode",
    "notation": "Nested objects. Flatten with '/' separators for code vars: color.brand.accent → color/brand/accent",
    "platforms": ["react-native"]
  },

  "color": {
    "surface": {
      "canvas":       { "$value": "#F2F2F4", "$desc": "Page background — muted cool gray" },
      "card":         { "$value": "#FFFFFF", "$desc": "Card surface, radius 26" },
      "soft":         { "$value": "#F6F6F8", "$desc": "Inset chips, inputs, segmented track" },
      "dim":          { "$value": "#ECECEF", "$desc": "Pressed state, skeleton" },
      "pill":         { "$value": "#1E1F22", "$desc": "Dark active pill (segmented control, avatar)" }
    },
    "ink": {
      "primary":      { "$value": "#17181A", "$desc": "Primary text — near-black" },
      "mute":         { "$value": "#84858C", "$desc": "Secondary text" },
      "faint":        { "$value": "#B9BAC2", "$desc": "Placeholder, disabled, inactive tab" },
      "inverse":      { "$value": "#FFFFFF", "$desc": "Text on dark pill" }
    },
    "brand": {
      "accent":       { "$value": "#F4590D", "$desc": "Saffron — CTA, active tab dot, sacred highlight" },
      "accent-wash":  { "$value": "#FEEFE6", "$desc": "Featured card tint (vrat/festival)" }
    },
    "data": {
      "sky":    { "$value": "#7EC4F0", "$wash": "#E9F5FD", "$desc": "Nakshatra, Vishnu/Krishna deity" },
      "indigo": { "$value": "#7D8CFB", "$wash": "#EDEFFE", "$desc": "Moonrise, Shiva deity" },
      "green":  { "$value": "#63BE7E", "$wash": "#E9F7EE", "$desc": "Yoga, Saraswati deity" },
      "coral":  { "$value": "#FC7F6C", "$wash": "#FEEEEB", "$desc": "Rahu Kalam, Devi/Hanuman deity" },
      "lime":   { "$value": "#D3EC5C", "$wash": "#F5FBDC", "$desc": "Positive badge (max one per screen)" },
      "amber":  { "$value": "#FFAE55", "$wash": "#FFF3E4", "$desc": "Sun ring, Ganesha deity" },
      "gray":   { "$value": "#A9AAB1", "$wash": "#F6F6F8", "$desc": "Universal / neutral" }
    },
    "semantic": {
      "success": { "$value": "#3BA55D" },
      "error":   { "$value": "#D9463E" },
      "hairline": { "$value": "#E8E8EC" }
    }
  },

  "radius": {
    "sm":   { "$value": 10 },
    "md":   { "$value": 16 },
    "chip": { "$value": 18 },
    "card": { "$value": 26, "$desc": "Signature big-radius card" },
    "pill": { "$value": 999 }
  },

  "type": {
    "displayXl": { "$value": "Manrope 800, 38/44, -0.8", "$desc": "Tithi hero" },
    "display":   { "$value": "Manrope 800, 30/36, -0.5", "$desc": "Ring center, section heroes" },
    "title":     { "$value": "Manrope 700, 21/28", "$desc": "Centered screen title" },
    "heading":   { "$value": "Manrope 700, 17/24", "$desc": "Card titles" },
    "label":     { "$value": "Manrope 700, 14/20", "$desc": "Legend rows, buttons" },
    "body":      { "$value": "Manrope 500, 15/23" },
    "bodySm":    { "$value": "Manrope 500, 13/19" },
    "caption":   { "$value": "Manrope 600, 12/16", "$desc": "Sentence case — never uppercase" },
    "captionSm": { "$value": "Manrope 600, 11/14" },
    "devanagari": { "$value": "System font, 19-21/1.6", "$desc": "Sanskrit never sets fontFamily" }
  },

  "shadow": {
    "card": { "$value": "0 4 14 rgba(23,24,26,0.05)", "$desc": "Barely-there ambient" }
  }
}
